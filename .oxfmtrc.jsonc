{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": false,
  "tabWidth": 4,
  "trailingComma": "es5",
  "overrides": [
    {
      // sadly, trailing commas are not generally supported by all jsonc parsers
      "files": ["*.jsonc"],
      "options": {
        "trailingComma": "none",
      },
    },
  ],
  "ignorePatterns": [
    ".tscache",
    "/bakedSite",
    "/localBake",
    "datasetsExport",
    "itsJustJavascript",
    "package.json",
    "coverage",
    "packages/@ourworldindata/*/dist/",
    "dist/",
    "grapherData/",
    ".vscode/",
    ".claude/settings.local.json",
    "*.handlebars",
  ],
}
